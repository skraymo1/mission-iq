# Mission IQ configuration. Copy to .env and adjust as needed.
# All values have working defaults pointing at the verified Foundry resource.

# Foundry / Azure OpenAI endpoint hosting the model deployment.
MISSIONIQ_FOUNDRY_ENDPOINT=https://missioniq-resource.cognitiveservices.azure.com/

# Model deployment name.
MISSIONIQ_MODEL=gpt-5.4

# API version for the /openai/v1 surface used by Agent Framework.
MISSIONIQ_API_VERSION=preview

# --- Live connectors (used by the "live" fundraising skin) -------------------
# Foundry *project* endpoint (Responses API + hosted connectors live here).
MISSIONIQ_PROJECT_ENDPOINT=https://missioniq-resource.services.ai.azure.com/api/projects/missionIQ

# Fabric Data Agent connection id. Published & wired: the `missioniq-fabric`
# connection (CustomKeys, holds workspace-id + artifact-id; auth is OBO identity
# passthrough). Defaults to the project's missioniq-fabric connection, so leaving
# this blank still lights up the 🗄️ Fabric plane. Override only to point elsewhere.
MISSIONIQ_FABRIC_CONNECTION_ID=

# Bing grounding + Azure AI Search connections (already created in the project).
# Defaults point at the real connections; override only if you recreate them.
MISSIONIQ_BING_CONNECTION_ID=
MISSIONIQ_SEARCH_CONNECTION_ID=
MISSIONIQ_SEARCH_INDEX=missioniq-fundraising-docs

# Set to 1 to let the Web plane attempt a real outbound lookup (falls back to
# the seeded snapshot on any failure). Default 0 keeps demos deterministic.
MISSIONIQ_LIVE_WEB=0
